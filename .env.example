# Official Clash Royale API token from https://developer.clashroyale.com
CR_API_TOKEN=your_official_clash_royale_api_token_here

# Optional: request timeout in seconds
CR_API_TIMEOUT_SECONDS=10

# Optional: save raw Clash API JSON in ./debug_raw
CR_SAVE_RAW_RESPONSE=0

# Optional: deck explorer cache TTL (seconds)
DECK_CACHE_SECONDS=900

# Optional: top ladder players to sample for explorer (10-100)
DECK_TOP_PLAYERS_LIMIT=40

# Optional: how long before status becomes stale (seconds)
STATUS_STALE_SECONDS=900

# Optional: label displayed in status tracker
APP_BUILD_LABEL=local-dev

# Ollama chat provider settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_SESSION_TTL_SECONDS=7200
OLLAMA_HISTORY_MESSAGES=8

# Local server port
PORT=8080
