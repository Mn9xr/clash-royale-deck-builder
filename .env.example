# Official Clash Royale API token from https://developer.clashroyale.com
CR_API_TOKEN=your_official_clash_royale_api_token_here

# Optional: request timeout in seconds
CR_API_TIMEOUT_SECONDS=10

# Optional: save raw Clash API JSON in ./debug_raw
CR_SAVE_RAW_RESPONSE=0

# Local server port
PORT=8080
